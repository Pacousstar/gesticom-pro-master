generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/@prisma/test-client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Produit {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  designation String
  categorie   String   @default("GENERAL")
  prixVente   Float?
  prixAchat   Float?
  pamp        Float?   @default(0)
  actif       Boolean  @default(true)
  entiteId    Int      @default(1)
  stocks      Stock[]
  ventesLignes VenteLigne[]
}

model Stock {
  id        Int     @id @default(autoincrement())
  produitId Int
  magasinId Int     @default(1)
  quantite  Float   @default(0)
  produit   Produit @relation(fields: [produitId], references: [id])
}

model Vente {
  id             Int          @id @default(autoincrement())
  numero         String       @unique
  date           DateTime     @default(now())
  magasinId      Int          @default(1)
  entiteId       Int          @default(1)
  utilisateurId  Int          @default(1)
  montantTotal   Float
  montantPaye    Float        @default(0)
  statutPaiement String       @default("PAYE")
  modePaiement   String       @default("ESPECES")
  pointsGagnes   Int          @default(0)
  estVenteRapide Boolean      @default(false)
  lignes         VenteLigne[]
}

model VenteLigne {
  id           Int      @id @default(autoincrement())
  venteId      Int
  produitId    Int
  designation  String
  quantite     Float
  prixUnitaire Float
  remise       Float    @default(0)
  montant      Float
  vente        Vente    @relation(fields: [venteId], references: [id], onDelete: Cascade)
  produit      Produit  @relation(fields: [produitId], references: [id])
}
