# Base de données SQLite (chemin local)
DATABASE_URL="file:./prisma/gesticom.db"

# Secret JWT pour les sessions - MINIMUM 32 caractères
# Générez un nouveau secret avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="votre-secret-jwt-a-generer-min-32-caracteres"

# Port du serveur (défaut: 3001)
PORT=3001

# Options supplémentaires (développement uniquement)
# GESTICOM_USE_PORTABLE_DB=1
# NODE_ENV=development