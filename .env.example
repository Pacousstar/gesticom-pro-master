# GestiCom Pro — Variables d'environnement
# Copier ce fichier vers .env et adapter les valeurs

# Base de données SQLite (chemin relatif à la racine du projet)
DATABASE_URL="file:./prisma/gesticom.db"

# Clé secrète pour les sessions JWT (minimum 32 caractères, changer impérativement)
SESSION_SECRET="votre-cle-secrete-tres-longue-dau-moins-32-caracteres"

# Port du serveur
PORT=3001

# URL du serveur de mise à jour (optionnel)
# UPDATE_URL="https://votre-domaine.com/gesticom-update"
